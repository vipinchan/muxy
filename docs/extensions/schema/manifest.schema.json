{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://muxy.app/schema/manifest.schema.json",
  "title": "Muxy Extension package.json",
  "description": "An extension is an npm + Vite project. Identity (name, version) lives at the top level of package.json; all Muxy manifest fields live under the `muxy` key. Mirror of the Swift PackageManifest/ExtensionManifest loader in muxy-app/muxy — source of truth is MuxyExtension.load/validate; this schema is the marketplace mirror, backed by an app contract test.",
  "type": "object",
  "required": ["name", "version", "scripts", "muxy"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional pointer to this schema for editor autocomplete. Ignored by the app loader."
    },
    "name": {
      "type": "string",
      "description": "Extension identifier. Must equal the directory name. ASCII letters, digits, dash, underscore, dot; no leading dot.",
      "pattern": "^(?!\\.)[A-Za-z0-9._-]+$",
      "minLength": 1,
      "maxLength": 64
    },
    "version": {
      "type": "string",
      "description": "Semver. A published name@version is immutable; bump for any change.",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z-.]+)?(?:\\+[0-9A-Za-z-.]+)?$"
    },
    "scripts": {
      "type": "object",
      "description": "npm scripts. A `build` script is required: the publishing pipeline runs it (Vite) and ships the build output (dist/).",
      "required": ["build"],
      "properties": {
        "build": { "type": "string", "minLength": 1 }
      }
    },
    "muxy": {
      "type": "object",
      "description": "All Muxy-specific manifest fields. Entry/asset paths resolve against the build output (dist/).",
      "additionalProperties": false,
      "properties": {
        "$schema": {
          "type": "string",
          "description": "Optional pointer to this schema. Ignored by the app loader."
        },
        "description": {
          "type": "string",
          "maxLength": 200
        },
        "background": {
          "type": "string",
          "description": "Relative path to a background JS file inside the build output. Use for pushed workspace events, extension-local events, remote methods, or background shell commands."
        },
        "events": {
          "type": "array",
          "description": "Workspace events this extension may subscribe to (e.g. pane.created, pane.closed, tab.created, tab.updated, tab.closed, tab.focused, panel.opened, panel.closed, popover.opened, popover.closed, project.switched, worktree.switched, notification.posted, file.changed). Same-extension `extension.*` events are local and are not declared here. Intercepting closes (muxy.lifecycle) needs no declaration.",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "permissions": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/permission" }
        },
        "tabTypes": {
          "type": "array",
          "items": { "$ref": "#/$defs/tabType" }
        },
        "panels": {
          "type": "array",
          "items": { "$ref": "#/$defs/panel" }
        },
        "popovers": {
          "type": "array",
          "items": { "$ref": "#/$defs/popover" }
        },
        "commands": {
          "type": "array",
          "items": { "$ref": "#/$defs/command" }
        },
        "topbarItems": {
          "type": "array",
          "items": { "$ref": "#/$defs/topbarItem" }
        },
        "statusBarItems": {
          "type": "array",
          "items": { "$ref": "#/$defs/statusBarItem" }
        },
        "settings": {
          "type": "array",
          "items": { "$ref": "#/$defs/setting" }
        },
        "remoteMethods": {
          "type": "array",
          "description": "Named API methods this extension serves to the mobile app via the remote server. Requires the `remote:serve` permission. Handlers are registered in the background script with `muxy.remote.handle(id, fn)`.",
          "items": { "$ref": "#/$defs/remoteMethod" }
        },
        "marketplace": {
          "type": "object",
          "description": "Listing metadata used by the marketplace. Required: icon + at least one screenshot. Ignored by the app loader. The pricing key is reserved for a future paid-extensions feature and is not yet enforced.",
          "additionalProperties": false,
          "required": ["icon", "screenshots"],
          "properties": {
            "author": { "type": "string" },
            "github": { "type": "string", "description": "Author's GitHub username." },
            "homepage": { "type": "string", "format": "uri" },
            "repository": { "type": "string", "format": "uri" },
            "categories": {
              "type": "array",
              "items": { "type": "string" },
              "uniqueItems": true
            },
            "icon": {
              "type": "string",
              "description": "Relative path to the listing icon inside the build output. SVG (preferred) or square PNG ≥256×256.",
              "pattern": "\\.(svg|png)$"
            },
            "screenshots": {
              "type": "array",
              "description": "Relative paths to listing screenshots inside the build output. At least one required. PNG, 1600×1000 (16:10).",
              "minItems": 1,
              "maxItems": 6,
              "uniqueItems": true,
              "items": { "type": "string", "pattern": "\\.png$" }
            },
            "pricing": {
              "type": "object",
              "description": "Reserved. Not enforced in v1.",
              "additionalProperties": true
            }
          }
        }
      }
    }
  },
  "$defs": {
    "permission": {
      "type": "string",
      "enum": [
        "panes:read",
        "panes:write",
        "tabs:read",
        "tabs:write",
        "projects:read",
        "projects:write",
        "projects:delete",
        "worktrees:read",
        "worktrees:write",
        "git:read",
        "git:write",
        "notifications:write",
        "panels:write",
        "commands:run-script",
        "commands:exec",
        "remote:serve"
      ]
    },
    "icon": {
      "description": "Either an SF Symbol name string, { symbol }, or { svg: relative-path }.",
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["symbol"],
          "properties": { "symbol": { "type": "string", "minLength": 1 } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["svg"],
          "properties": { "svg": { "type": "string", "minLength": 1 } }
        }
      ]
    },
    "tabType": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "entry"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string" },
        "entry": { "type": "string", "minLength": 1 },
        "defaultData": {}
      }
    },
    "panel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "entry"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string" },
        "icon": { "$ref": "#/$defs/icon" },
        "entry": { "type": "string", "minLength": 1 },
        "position": { "enum": ["right", "bottom"] },
        "mode": { "enum": ["pinned", "floating"] },
        "hiddenControls": {
          "type": "array",
          "items": { "enum": ["icon", "title", "close", "pin", "position"] },
          "uniqueItems": true
        },
        "headerButtons": {
          "type": "array",
          "items": { "$ref": "#/$defs/panelHeaderButton" }
        },
        "defaultData": {}
      }
    },
    "panelHeaderButton": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "icon", "command"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "icon": { "$ref": "#/$defs/icon" },
        "tooltip": { "type": "string" },
        "command": { "type": "string", "minLength": 1 }
      }
    },
    "popover": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "entry"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string" },
        "entry": { "type": "string", "minLength": 1 },
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 },
        "defaultData": {}
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "action": { "$ref": "#/$defs/commandAction" },
        "defaultShortcut": {
          "type": "string",
          "minLength": 1,
          "description": "Default keyboard shortcut for this command, e.g. \"cmd+shift+e\". Must include at least one of cmd, ctrl, or opt; bare keys are ignored. Auto-assigned on load when free; registered unassigned when the combo is already taken. Editable in Settings → Keyboard Shortcuts."
        }
      }
    },
    "commandAction": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": { "enum": ["event", "openTab", "togglePanel", "openPopover", "runScript"] }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "openTab" } } },
          "then": {
            "required": ["tabType"],
            "properties": {
              "kind": {},
              "tabType": { "type": "string", "minLength": 1 },
              "data": {}
            },
            "additionalProperties": false
          }
        },
        {
          "if": { "properties": { "kind": { "const": "togglePanel" } } },
          "then": {
            "required": ["panel"],
            "properties": {
              "kind": {},
              "panel": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        },
        {
          "if": { "properties": { "kind": { "const": "openPopover" } } },
          "then": {
            "required": ["popover"],
            "properties": {
              "kind": {},
              "popover": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        },
        {
          "if": { "properties": { "kind": { "const": "runScript" } } },
          "then": {
            "required": ["script"],
            "properties": {
              "kind": {},
              "script": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        },
        {
          "if": { "properties": { "kind": { "const": "event" } } },
          "then": {
            "properties": { "kind": {} },
            "additionalProperties": false
          }
        }
      ]
    },
    "topbarItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "icon", "command"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "icon": { "$ref": "#/$defs/icon" },
        "tooltip": { "type": "string" },
        "command": { "type": "string", "minLength": 1 },
        "visible": { "type": "boolean" }
      }
    },
    "statusBarItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "icon", "side", "command"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "icon": { "$ref": "#/$defs/icon" },
        "text": { "type": "string" },
        "tooltip": { "type": "string" },
        "side": { "enum": ["left", "right"] },
        "command": { "type": "string", "minLength": 1 },
        "visible": { "type": "boolean" }
      }
    },
    "setting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "title", "type"],
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "enum": ["string", "bool", "number"] },
        "defaultValue": {}
      }
    },
    "remoteMethod": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "description": { "type": "string" }
      }
    }
  }
}
