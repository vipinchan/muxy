#!/bin/bash
# Muxy CLI wrapper
# Usage:
#   muxy <path>                                Open a folder in Muxy
#   muxy split-right [--from <id>] [cmd...]    Split horizontally from the calling pane (returns pane ID)
#   muxy split-down [--from <id>] [cmd...]     Split vertically from the calling pane (returns pane ID)
#   muxy send --pane <id> <text>               Send text to a pane
#   muxy send-keys --pane <id> <key>           Send special key (Escape, Enter, Tab, Ctrl+C)
#   muxy read-screen --pane <id> [--lines N]   Read terminal content
#   muxy close-pane --pane <id>                Close a pane
#   muxy rename-pane --pane <id> <title>       Rename a pane tab
#   muxy list-panes                            List all panes (tab-separated)
#   muxy list-projects                         List projects
#   muxy switch-project <name|id|path>         Switch active project
#   muxy list-worktrees [project]              List worktrees
#   muxy create-worktree <name> [options]      Create and switch to a worktree
#   muxy switch-worktree <name|id|path>        Switch active worktree
#   muxy refresh-worktrees [project]           Refresh worktrees from Git
#   muxy list-tabs                             List tabs
#   muxy switch-tab <index|id|title>           Switch active tab
#   muxy new-tab                               Create a terminal tab
#   muxy next-tab|previous-tab                 Switch tabs
#   muxy install-skills [skills args...]       Install Muxy agent skills into detected AI harnesses
#
# Run "muxy <command> --help" for the options of a single command.

COMMAND="$1"
SOCKET="${MUXY_SOCKET_PATH:-$HOME/Library/Application Support/Muxy/muxy.sock}"
NC_TIMEOUT="${MUXY_CLI_TIMEOUT:-10}"

usage_for() {
    case "$1" in
        split-right)       echo "muxy split-right [--from <id>] [cmd...]" ;;
        split-down)        echo "muxy split-down [--from <id>] [cmd...]" ;;
        send)              echo "muxy send --pane <id> <text>" ;;
        send-keys)         echo "muxy send-keys --pane <id> <key>" ;;
        read-screen)       echo "muxy read-screen --pane <id> [--lines N]" ;;
        close-pane)        echo "muxy close-pane --pane <id>" ;;
        rename-pane)       echo "muxy rename-pane --pane <id> <title>" ;;
        list-panes)        echo "muxy list-panes" ;;
        list-projects)     echo "muxy list-projects" ;;
        switch-project)    echo "muxy switch-project <name|id|path>" ;;
        list-worktrees)    echo "muxy list-worktrees [project]" ;;
        create-worktree)   echo "muxy create-worktree <name> [--branch <branch>] [--base <branch>] [--project <project>] [--path <path>] [--existing]" ;;
        switch-worktree)   echo "muxy switch-worktree <name|id|path> [--project <name|id|path>]" ;;
        refresh-worktrees) echo "muxy refresh-worktrees [project]" ;;
        list-tabs)         echo "muxy list-tabs" ;;
        switch-tab)        echo "muxy switch-tab <index|id|title>" ;;
        new-tab)           echo "muxy new-tab" ;;
        next-tab)          echo "muxy next-tab" ;;
        previous-tab)      echo "muxy previous-tab" ;;
        browser)           echo "muxy browser <open|navigate|list|read|close|eval|click|type|fill|press|select|hover|check|uncheck|scroll-into-view|wait|wait-for|wait-for-navigation|get-text|get-html|get-value|get-attribute|get-count|is|find|snapshot|reload|back|forward|screenshot|storage|cookies> [args...]" ;;
        install-skills)    echo "muxy install-skills [skills args...]" ;;
    esac
}

die_usage() {
    echo "Usage: $(usage_for "$1")" >&2
    exit 1
}

print_command_help() {
    echo "Usage: $(usage_for "$1")"
    exit 0
}

wants_help() {
    [ "$1" = "-h" ] || [ "$1" = "--help" ]
}

usage() {
    echo "Usage:"
    echo "  muxy <path>                              Open a folder in Muxy"
    echo "  muxy split-right [--from <id>] [cmd...]  Split horizontally from the calling pane (returns pane ID)"
    echo "  muxy split-down [--from <id>] [cmd...]   Split vertically from the calling pane (returns pane ID)"
    echo "  muxy send --pane <id> <text>             Send text to a pane"
    echo "  muxy send-keys --pane <id> <key>         Send special key (Escape, Enter, Tab, Ctrl+C)"
    echo "  muxy read-screen --pane <id> [--lines N] Read terminal content"
    echo "  muxy close-pane --pane <id>              Close a pane"
    echo "  muxy rename-pane --pane <id> <title>     Rename a pane tab"
    echo "  muxy list-panes                          List all panes"
    echo "  muxy list-projects                       List projects"
    echo "  muxy switch-project <name|id|path>       Switch active project"
    echo "  muxy list-worktrees [project]            List worktrees"
    echo "  muxy create-worktree <name> [options]    Create and switch to a worktree"
    echo "  muxy switch-worktree <name|id|path>      Switch active worktree"
    echo "  muxy refresh-worktrees [project]         Refresh worktrees from Git"
    echo "  muxy list-tabs                           List tabs"
    echo "  muxy switch-tab <index|id|title>         Switch active tab"
    echo "  muxy new-tab                             Create a terminal tab"
    echo "  muxy next-tab                            Switch to next tab"
    echo "  muxy previous-tab                        Switch to previous tab"
    echo "  muxy browser open <url> [--split]        Open a URL in a built-in browser tab (returns tab ID)"
    echo "  muxy browser navigate <tab-id> <url>     Navigate a browser tab to a URL"
    echo "  muxy browser list                        List built-in browser tabs"
    echo "  muxy browser read <tab-id>               Read a browser tab's title and text"
    echo "  muxy browser close <tab-id>              Close a browser tab"
    echo "  muxy browser eval <tab-id> <js>          Run JavaScript in the page and return its JSON result"
    echo "  muxy browser click <tab-id> <selector>   Click the first element matching a CSS selector"
    echo "  muxy browser type <tab-id> <sel> <text> [--submit]  Type text into an element"
    echo "  muxy browser wait-for <tab-id> <sel> [ms] Wait until a selector appears"
    echo "  muxy browser fill <tab-id> <sel> <text>  Replace an input's value"
    echo "  muxy browser press <tab-id> <key> [sel]  Dispatch a key (Enter, Tab, …)"
    echo "  muxy browser select <tab-id> <sel> <val> Select an <option> by value"
    echo "  muxy browser hover|scroll-into-view <tab-id> <sel>  Hover / scroll to an element"
    echo "  muxy browser check|uncheck <tab-id> <sel> Toggle a checkbox"
    echo "  muxy browser wait <tab-id> [--selector|--text|--url-contains|--function v] [--timeout-ms N]  Wait for a condition"
    echo "  muxy browser is <tab-id> <visible|enabled|checked> <sel>  Assert element state"
    echo "  muxy browser get-text <tab-id> <selector> Read an element's innerText"
    echo "  muxy browser get-html <tab-id> [selector] Read an element's (or the page's) HTML"
    echo "  muxy browser get-value <tab-id> <selector> Read an input's value"
    echo "  muxy browser get-attribute <tab-id> <sel> <attr>  Read an element attribute"
    echo "  muxy browser get-count <tab-id> <selector> Count matching elements"
    echo "  muxy browser find <tab-id> <role|text|label|placeholder|testid> <value>  Find elements semantically"
    echo "  muxy browser snapshot <tab-id> [selector] List visible interactive elements (for agents)"
    echo "  muxy browser reload|back|forward <tab-id> Navigate browser history"
    echo "  muxy browser wait-for-navigation <tab-id> [ms]  Wait for the page to finish loading"
    echo "  muxy browser screenshot <tab-id>         Capture a PNG (base64) of the page"
    echo "  muxy browser storage get|set|clear <tab-id> ...  Read/write local or session storage"
    echo "  muxy browser cookies get|set|delete|clear <tab-id> ...  Manage cookies"
    echo "  muxy install-skills [skills args...]     Install Muxy agent skills into detected AI harnesses"
    echo ""
    echo "Run \"muxy <command> --help\" for the options of a single command."
}

send_command() {
    local message="$1"
    local timeout="${2:-$NC_TIMEOUT}"
    if [ ! -e "$SOCKET" ]; then
        echo "Error: Muxy is not running" >&2
        exit 1
    fi

    local raw
    raw=$(mktemp "${TMPDIR:-/tmp}/muxy-cli.XXXXXX") || {
        echo "Error: could not create temporary file" >&2
        exit 1
    }
    trap 'rm -f "$raw"' EXIT

    printf '%s\n' "$message" | nc -w "$timeout" -U "$SOCKET" > "$raw" 2>/dev/null

    if [ "$(tail -c1 "$raw" | od -An -tu1 | tr -d ' ')" != "0" ]; then
        echo "Error: no response from Muxy" >&2
        exit 1
    fi

    local response
    response=$(cat "$raw")
    case "$response" in
        error:*)
            echo "${response#error:}" >&2
            exit 1
            ;;
        *)
            printf '%s\n' "$response"
            ;;
    esac
}

json_escape() {
    local s="$1" out="" i c
    for (( i=0; i<${#s}; i++ )); do
        c="${s:$i:1}"
        case "$c" in
            '"') out+='\"' ;;
            '\') out+='\\' ;;
            $'\n') out+='\n' ;;
            $'\r') out+='\r' ;;
            $'\t') out+='\t' ;;
            *) out+="$c" ;;
        esac
    done
    printf '%s' "$out"
}

json_field() {
    printf '"%s":"%s"' "$1" "$(json_escape "$2")"
}

send_api() {
    local verb="$1"
    local json="$2"
    local timeout="${3:-$NC_TIMEOUT}"
    local payload
    payload=$(printf '%s' "$json" | base64 | tr -d '\n')
    local reply
    reply=$(send_command "$verb|$payload" "$timeout") || exit 1
    if [ -z "$reply" ]; then
        printf '\n'
        return 0
    fi
    printf '%s' "$reply" | base64 -D 2>/dev/null && printf '\n'
}

api_timeout_for_ms() {
    local ms="$1"
    echo $(( ms / 1000 + NC_TIMEOUT ))
}

case "$COMMAND" in
    split-right)
        shift
        FROM="${MUXY_PANE_ID:-}"
        CMD_ARGS=()
        while [[ $# -gt 0 ]]; do
            case $1 in
                -h|--help) print_command_help split-right ;;
                --from)
                    [ $# -lt 2 ] && die_usage split-right
                    FROM="$2"
                    shift 2
                    ;;
                *) CMD_ARGS+=("$1"); shift ;;
            esac
        done
        CMD="${CMD_ARGS[*]}"
        if [ -n "$CMD" ] || [ -n "$FROM" ]; then
            send_command "split-right|$FROM|$CMD"
        else
            send_command "split-right"
        fi
        ;;
    split-down)
        shift
        FROM="${MUXY_PANE_ID:-}"
        CMD_ARGS=()
        while [[ $# -gt 0 ]]; do
            case $1 in
                -h|--help) print_command_help split-down ;;
                --from)
                    [ $# -lt 2 ] && die_usage split-down
                    FROM="$2"
                    shift 2
                    ;;
                *) CMD_ARGS+=("$1"); shift ;;
            esac
        done
        CMD="${CMD_ARGS[*]}"
        if [ -n "$CMD" ] || [ -n "$FROM" ]; then
            send_command "split-down|$FROM|$CMD"
        else
            send_command "split-down"
        fi
        ;;
    send)
        shift
        PANE_ID=""
        TEXT=""
        while [[ $# -gt 0 ]]; do
            case $1 in
                -h|--help) print_command_help send ;;
                --pane) PANE_ID="$2"; shift 2 ;;
                *) TEXT="$1"; shift ;;
            esac
        done
        if [ -z "$PANE_ID" ] || [ -z "$TEXT" ]; then
            die_usage send
        fi
        send_command "send|$PANE_ID|$TEXT"
        ;;
    send-keys)
        shift
        PANE_ID=""
        KEY=""
        while [[ $# -gt 0 ]]; do
            case $1 in
                -h|--help) print_command_help send-keys ;;
                --pane) PANE_ID="$2"; shift 2 ;;
                *) KEY="$1"; shift ;;
            esac
        done
        if [ -z "$PANE_ID" ] || [ -z "$KEY" ]; then
            die_usage send-keys
        fi
        send_command "send-keys|$PANE_ID|$KEY"
        ;;
    read-screen)
        shift
        PANE_ID=""
        LINES=50
        while [[ $# -gt 0 ]]; do
            case $1 in
                -h|--help) print_command_help read-screen ;;
                --pane) PANE_ID="$2"; shift 2 ;;
                --lines) LINES="$2"; shift 2 ;;
                *) shift ;;
            esac
        done
        if [ -z "$PANE_ID" ]; then
            die_usage read-screen
        fi
        send_command "read-screen|$PANE_ID|$LINES"
        ;;
    close-pane)
        shift
        PANE_ID=""
        while [[ $# -gt 0 ]]; do
            case $1 in
                -h|--help) print_command_help close-pane ;;
                --pane) PANE_ID="$2"; shift 2 ;;
                *) shift ;;
            esac
        done
        if [ -z "$PANE_ID" ]; then
            die_usage close-pane
        fi
        send_command "close-pane|$PANE_ID"
        ;;
    rename-pane)
        shift
        PANE_ID=""
        TITLE=""
        while [[ $# -gt 0 ]]; do
            case $1 in
                -h|--help) print_command_help rename-pane ;;
                --pane) PANE_ID="$2"; shift 2 ;;
                *) TITLE="$1"; shift ;;
            esac
        done
        if [ -z "$PANE_ID" ] || [ -z "$TITLE" ]; then
            die_usage rename-pane
        fi
        send_command "rename-pane|$PANE_ID|$TITLE"
        ;;
    list-panes)
        wants_help "$2" && print_command_help list-panes
        send_command "list-panes"
        ;;
    list-projects)
        wants_help "$2" && print_command_help list-projects
        send_command "list-projects"
        ;;
    switch-project)
        shift
        wants_help "$1" && print_command_help switch-project
        if [ $# -lt 1 ]; then
            die_usage switch-project
        fi
        send_command "switch-project|$*"
        ;;
    list-worktrees)
        shift
        wants_help "$1" && print_command_help list-worktrees
        if [ $# -gt 0 ]; then
            send_command "list-worktrees|$*"
        else
            send_command "list-worktrees"
        fi
        ;;
    create-worktree)
        shift
        NAME=""
        BRANCH=""
        PROJECT=""
        PATH_ARG=""
        CREATE_BRANCH="true"
        BASE_BRANCH=""
        while [[ $# -gt 0 ]]; do
            case $1 in
                -h|--help) print_command_help create-worktree ;;
                --branch)
                    [ $# -lt 2 ] && die_usage create-worktree
                    BRANCH="$2"
                    shift 2
                    ;;
                --base)
                    [ $# -lt 2 ] && die_usage create-worktree
                    BASE_BRANCH="$2"
                    shift 2
                    ;;
                --project)
                    [ $# -lt 2 ] && die_usage create-worktree
                    PROJECT="$2"
                    shift 2
                    ;;
                --path)
                    [ $# -lt 2 ] && die_usage create-worktree
                    PATH_ARG="$2"
                    shift 2
                    ;;
                --existing)
                    CREATE_BRANCH="false"
                    shift
                    ;;
                *)
                    if [ -z "$NAME" ]; then
                        NAME="$1"
                    else
                        die_usage create-worktree
                    fi
                    shift
                    ;;
            esac
        done
        if [ -z "$NAME" ]; then
            die_usage create-worktree
        fi
        if [ -z "$BRANCH" ]; then
            BRANCH="$NAME"
        fi
        send_command "create-worktree|$NAME|$BRANCH|$PROJECT|$PATH_ARG|$CREATE_BRANCH|$BASE_BRANCH"
        ;;
    switch-worktree)
        shift
        PROJECT=""
        TARGET_ARGS=()
        while [[ $# -gt 0 ]]; do
            case $1 in
                -h|--help) print_command_help switch-worktree ;;
                --project)
                    [ $# -lt 2 ] && die_usage switch-worktree
                    shift
                    PROJECT="$*"
                    break
                    ;;
                *) TARGET_ARGS+=("$1"); shift ;;
            esac
        done
        TARGET="${TARGET_ARGS[*]}"
        if [ -z "$TARGET" ]; then
            die_usage switch-worktree
        fi
        if [ -n "$PROJECT" ]; then
            send_command "switch-worktree|$TARGET|$PROJECT"
        else
            send_command "switch-worktree|$TARGET"
        fi
        ;;
    refresh-worktrees)
        shift
        wants_help "$1" && print_command_help refresh-worktrees
        if [ $# -gt 0 ]; then
            send_command "refresh-worktrees|$*"
        else
            send_command "refresh-worktrees"
        fi
        ;;
    list-tabs)
        wants_help "$2" && print_command_help list-tabs
        send_command "list-tabs"
        ;;
    switch-tab)
        shift
        wants_help "$1" && print_command_help switch-tab
        if [ $# -lt 1 ]; then
            die_usage switch-tab
        fi
        send_command "switch-tab|$*"
        ;;
    new-tab)
        wants_help "$2" && print_command_help new-tab
        send_command "new-tab"
        ;;
    next-tab)
        wants_help "$2" && print_command_help next-tab
        send_command "next-tab"
        ;;
    previous-tab)
        wants_help "$2" && print_command_help previous-tab
        send_command "previous-tab"
        ;;
    install-skills)
        shift
        wants_help "$1" && print_command_help install-skills
        if ! command -v npx >/dev/null 2>&1; then
            echo "Error: npx not found. Install Node.js to run this command." >&2
            exit 1
        fi
        SKILLS_REPO="github.com/muxy-app/muxy/tree/main/Muxy/Resources/skills"
        for skill in muxy-cli muxy-extension; do
            npx --yes skills add "$SKILLS_REPO/$skill" --global --yes "$@" || exit 1
        done
        exit 0
        ;;
    browser)
        shift
        wants_help "$1" && print_command_help browser
        SUB="${1:-}"
        shift || true
        case "$SUB" in
            open)
                URL=""
                SPLIT=""
                HAS_URL=""
                while [[ $# -gt 0 ]]; do
                    case $1 in
                        --split) SPLIT="--split"; shift ;;
                        *)
                            [ -n "$HAS_URL" ] && die_usage browser
                            URL="$1"; HAS_URL="1"; shift
                            ;;
                    esac
                done
                if [ -n "$SPLIT" ]; then
                    if [ -n "$HAS_URL" ]; then
                        send_command "browser.open|$URL|$SPLIT"
                    else
                        send_command "browser.open|$SPLIT"
                    fi
                elif [ -n "$HAS_URL" ]; then
                    send_command "browser.open|$URL"
                else
                    send_command "browser.open"
                fi
                ;;
            navigate)
                [ $# -lt 2 ] && die_usage browser
                send_command "browser.navigate|$1|$2"
                ;;
            list)
                send_command "browser.list"
                ;;
            read)
                [ $# -lt 1 ] && die_usage browser
                send_command "browser.read|$1"
                ;;
            close)
                [ $# -lt 1 ] && die_usage browser
                send_command "browser.close|$1"
                ;;
            eval)
                [ $# -lt 2 ] && die_usage browser
                send_api "browser.eval" "{$(json_field tabId "$1"),$(json_field script "$2")}"
                ;;
            click)
                [ $# -lt 2 ] && die_usage browser
                send_api "browser.click" "{$(json_field tabId "$1"),$(json_field selector "$2")}"
                ;;
            type)
                [ $# -lt 3 ] && die_usage browser
                SUBMIT="false"
                [ "${4:-}" = "--submit" ] && SUBMIT="true"
                send_api "browser.type" "{$(json_field tabId "$1"),$(json_field selector "$2"),$(json_field text "$3"),\"submit\":$SUBMIT}"
                ;;
            wait-for)
                [ $# -lt 2 ] && die_usage browser
                TIMEOUT="${3:-5000}"
                send_api "browser.waitFor" "{$(json_field tabId "$1"),$(json_field selector "$2"),\"timeoutMs\":$TIMEOUT}" "$(api_timeout_for_ms "$TIMEOUT")"
                ;;
            get-text)
                [ $# -lt 2 ] && die_usage browser
                send_api "browser.getText" "{$(json_field tabId "$1"),$(json_field selector "$2")}"
                ;;
            get-html)
                [ $# -lt 1 ] && die_usage browser
                if [ $# -ge 2 ]; then
                    send_api "browser.getHTML" "{$(json_field tabId "$1"),$(json_field selector "$2")}"
                else
                    send_api "browser.getHTML" "{$(json_field tabId "$1")}"
                fi
                ;;
            get-attribute)
                [ $# -lt 3 ] && die_usage browser
                send_api "browser.getAttribute" "{$(json_field tabId "$1"),$(json_field selector "$2"),$(json_field attribute "$3")}"
                ;;
            reload)
                [ $# -lt 1 ] && die_usage browser
                send_api "browser.reload" "{$(json_field tabId "$1")}"
                ;;
            back)
                [ $# -lt 1 ] && die_usage browser
                send_api "browser.back" "{$(json_field tabId "$1")}"
                ;;
            forward)
                [ $# -lt 1 ] && die_usage browser
                send_api "browser.forward" "{$(json_field tabId "$1")}"
                ;;
            wait-for-navigation)
                [ $# -lt 1 ] && die_usage browser
                WNTAB="$1"; shift
                TIMEOUT="10000"
                while [ $# -gt 0 ]; do
                    case "$1" in
                        --timeout-ms) TIMEOUT="$2"; shift 2 ;;
                        *) TIMEOUT="$1"; shift ;;
                    esac
                done
                send_api "browser.waitForNavigation" "{$(json_field tabId "$WNTAB"),\"timeoutMs\":$TIMEOUT}" "$(api_timeout_for_ms "$TIMEOUT")"
                ;;
            screenshot)
                [ $# -lt 1 ] && die_usage browser
                send_api "browser.screenshot" "{$(json_field tabId "$1")}"
                ;;
            storage)
                STORAGE_OP="${1:-}"
                shift || true
                case "$STORAGE_OP" in
                    get)
                        [ $# -lt 2 ] && die_usage browser
                        send_api "browser.storage.get" "{$(json_field tabId "$1"),$(json_field key "$2"),$(json_field kind "${3:-local}")}"
                        ;;
                    set)
                        [ $# -lt 3 ] && die_usage browser
                        send_api "browser.storage.set" "{$(json_field tabId "$1"),$(json_field key "$2"),$(json_field value "$3"),$(json_field kind "${4:-local}")}"
                        ;;
                    clear)
                        [ $# -lt 1 ] && die_usage browser
                        send_api "browser.storage.clear" "{$(json_field tabId "$1"),$(json_field kind "${2:-local}")}"
                        ;;
                    *)
                        die_usage browser
                        ;;
                esac
                ;;
            cookies)
                COOKIE_OP="${1:-}"
                shift || true
                case "$COOKIE_OP" in
                    get)
                        [ $# -lt 1 ] && die_usage browser
                        if [ $# -ge 2 ]; then
                            send_api "browser.cookies.get" "{$(json_field tabId "$1"),$(json_field url "$2")}"
                        else
                            send_api "browser.cookies.get" "{$(json_field tabId "$1")}"
                        fi
                        ;;
                    set)
                        [ $# -lt 4 ] && die_usage browser
                        send_api "browser.cookies.set" "{$(json_field tabId "$1"),$(json_field name "$2"),$(json_field value "$3"),$(json_field domain "$4")}"
                        ;;
                    delete)
                        [ $# -lt 2 ] && die_usage browser
                        if [ $# -ge 3 ]; then
                            send_api "browser.cookies.delete" "{$(json_field tabId "$1"),$(json_field name "$2"),$(json_field domain "$3")}"
                        else
                            send_api "browser.cookies.delete" "{$(json_field tabId "$1"),$(json_field name "$2")}"
                        fi
                        ;;
                    clear)
                        [ $# -lt 1 ] && die_usage browser
                        send_api "browser.cookies.clear" "{$(json_field tabId "$1")}"
                        ;;
                    *)
                        die_usage browser
                        ;;
                esac
                ;;
            wait)
                [ $# -lt 1 ] && die_usage browser
                WTAB="$1"; shift
                WSEL=""; WTEXT=""; WURL=""; WFUNC=""; WTIMEOUT="5000"
                while [ $# -gt 0 ]; do
                    case "$1" in
                        --selector) WSEL="$2"; shift 2 ;;
                        --text) WTEXT="$2"; shift 2 ;;
                        --url-contains) WURL="$2"; shift 2 ;;
                        --function) WFUNC="$2"; shift 2 ;;
                        --timeout-ms) WTIMEOUT="$2"; shift 2 ;;
                        *) die_usage browser ;;
                    esac
                done
                FIELDS="$(json_field tabId "$WTAB"),\"timeoutMs\":$WTIMEOUT"
                [ -n "$WSEL" ] && FIELDS="$FIELDS,$(json_field selector "$WSEL")"
                [ -n "$WTEXT" ] && FIELDS="$FIELDS,$(json_field text "$WTEXT")"
                [ -n "$WURL" ] && FIELDS="$FIELDS,$(json_field urlContains "$WURL")"
                [ -n "$WFUNC" ] && FIELDS="$FIELDS,$(json_field function "$WFUNC")"
                send_api "browser.wait" "{$FIELDS}" "$(api_timeout_for_ms "$WTIMEOUT")"
                ;;
            fill)
                [ $# -lt 3 ] && die_usage browser
                send_api "browser.fill" "{$(json_field tabId "$1"),$(json_field selector "$2"),$(json_field text "$3")}"
                ;;
            press)
                [ $# -lt 2 ] && die_usage browser
                if [ $# -ge 3 ]; then
                    send_api "browser.press" "{$(json_field tabId "$1"),$(json_field key "$2"),$(json_field selector "$3")}"
                else
                    send_api "browser.press" "{$(json_field tabId "$1"),$(json_field key "$2")}"
                fi
                ;;
            select)
                [ $# -lt 3 ] && die_usage browser
                send_api "browser.select" "{$(json_field tabId "$1"),$(json_field selector "$2"),$(json_field value "$3")}"
                ;;
            hover)
                [ $# -lt 2 ] && die_usage browser
                send_api "browser.hover" "{$(json_field tabId "$1"),$(json_field selector "$2")}"
                ;;
            scroll-into-view)
                [ $# -lt 2 ] && die_usage browser
                send_api "browser.scrollIntoView" "{$(json_field tabId "$1"),$(json_field selector "$2")}"
                ;;
            check)
                [ $# -lt 2 ] && die_usage browser
                send_api "browser.setChecked" "{$(json_field tabId "$1"),$(json_field selector "$2"),\"checked\":true}"
                ;;
            uncheck)
                [ $# -lt 2 ] && die_usage browser
                send_api "browser.setChecked" "{$(json_field tabId "$1"),$(json_field selector "$2"),\"checked\":false}"
                ;;
            is)
                [ $# -lt 3 ] && die_usage browser
                send_api "browser.is" "{$(json_field tabId "$1"),$(json_field property "$2"),$(json_field selector "$3")}"
                ;;
            get-value)
                [ $# -lt 2 ] && die_usage browser
                send_api "browser.getValue" "{$(json_field tabId "$1"),$(json_field selector "$2")}"
                ;;
            get-count)
                [ $# -lt 2 ] && die_usage browser
                send_api "browser.getCount" "{$(json_field tabId "$1"),$(json_field selector "$2")}"
                ;;
            find)
                [ $# -lt 3 ] && die_usage browser
                send_api "browser.find" "{$(json_field tabId "$1"),$(json_field kind "$2"),$(json_field value "$3")}"
                ;;
            snapshot)
                [ $# -lt 1 ] && die_usage browser
                if [ $# -ge 2 ]; then
                    send_api "browser.snapshot" "{$(json_field tabId "$1"),$(json_field selector "$2")}"
                else
                    send_api "browser.snapshot" "{$(json_field tabId "$1")}"
                fi
                ;;
            *)
                die_usage browser
                ;;
        esac
        exit 0
        ;;
    ""|--help|-h)
        usage
        [ -z "$COMMAND" ] && exit 1
        exit 0
        ;;
esac

# If we reach here, it's a path to open
if [ -n "$COMMAND" ] && [ "$COMMAND" != "split-right" ] && [ "$COMMAND" != "split-down" ] && \
   [ "$COMMAND" != "send" ] && [ "$COMMAND" != "send-keys" ] && [ "$COMMAND" != "read-screen" ] && \
   [ "$COMMAND" != "close-pane" ] && [ "$COMMAND" != "rename-pane" ] && [ "$COMMAND" != "list-panes" ] && \
   [ "$COMMAND" != "list-projects" ] && [ "$COMMAND" != "switch-project" ] && \
    [ "$COMMAND" != "list-worktrees" ] && [ "$COMMAND" != "create-worktree" ] && \
    [ "$COMMAND" != "switch-worktree" ] && \
   [ "$COMMAND" != "refresh-worktrees" ] && [ "$COMMAND" != "list-tabs" ] && \
   [ "$COMMAND" != "switch-tab" ] && [ "$COMMAND" != "new-tab" ] && \
   [ "$COMMAND" != "next-tab" ] && [ "$COMMAND" != "previous-tab" ] && \
   [ "$COMMAND" != "install-skills" ]; then
    TARGET_DIR="$COMMAND"

    case "$TARGET_DIR" in
        ~*) TARGET_DIR="${HOME}${TARGET_DIR:1}" ;;
        .)  TARGET_DIR="$(pwd)" ;;
        ..) TARGET_DIR="$(cd .. && pwd)" ;;
        *)  TARGET_DIR="$(cd "$TARGET_DIR" 2>/dev/null && pwd)" ;;
    esac

    if [ ! -d "$TARGET_DIR" ]; then
        echo "Error: $TARGET_DIR is not a valid directory" >&2
        exit 1
    fi

    percent_encode() {
        local string="$1" length=${#1} i c
        for (( i = 0; i < length; i++ )); do
            c="${string:i:1}"
            case "$c" in
                [a-zA-Z0-9.~_/-]) printf '%s' "$c" ;;
                *) printf '%%%02X' "'$c" ;;
            esac
        done
    }

    ENCODED_PATH="$(percent_encode "$TARGET_DIR")"

    if [ -e "$SOCKET" ] && printf '%s\n' "open-project|$TARGET_DIR" | nc -w "$NC_TIMEOUT" -U "$SOCKET" >/dev/null 2>&1; then
        exit 0
    fi

    open "muxy://open?path=${ENCODED_PATH}" 2>/dev/null \
        || open -b com.muxy.app "$TARGET_DIR" 2>/dev/null
fi
